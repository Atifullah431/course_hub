# Environment Variables for Server

# MongoDB
MONGODB_URI=mongodb://localhost:27017/course_hub

# JWT
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=development

# Client URL
CLIENT_URL=http://localhost:3000

# Payment Gateway Keys (Add your actual keys)
EASYPAISA_MERCHANT_ID=your-easypaisa-merchant-id
EASYPAISA_API_KEY=your-easypaisa-api-key
JAZZCASH_MERCHANT_ID=your-jazzcash-merchant-id
JAZZCASH_API_KEY=your-jazzcash-api-key
